SVI_DB_PATH=data/super_voice_input.db
SVI_PROMPTS_DIR=prompts
SVI_DEFAULT_STT_PROVIDER=doubao
SVI_DEFAULT_REWRITE_PROVIDER=deepseek

# Public URL of THIS API for Doubao to download audio (tunnel ngrok/cloudflare -> http://127.0.0.1:8000)
# Example: https://abc.ngrok-free.app  (no trailing slash)
SVI_PUBLIC_BASE_URL=

# STT: Doubao OpenSpeech (required for real transcription)
DOUBAO_BASE_URL=https://openspeech.bytedance.com/api/v3
DOUBAO_API_KEY=
DOUBAO_RESOURCE_ID=volc.bigasr.auc
DOUBAO_USER_ID=svi-local-user
DOUBAO_LANGUAGE=
DOUBAO_ENABLE_ITN=true
DOUBAO_SUBMIT_PATH=/auc/bigmodel/submit
DOUBAO_QUERY_PATH=/auc/bigmodel/query
DOUBAO_POLL_INTERVAL_MS=1200
DOUBAO_POLL_TIMEOUT_MS=90000
# Optional: map local storage path to a full URL prefix
DOUBAO_AUDIO_URL_PREFIX=

# Rewrite: DeepSeek (required for real rewriting)
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_API_KEY=
DEEPSEEK_REWRITE_MODEL=deepseek-chat
DEEPSEEK_REWRITE_PATH=/chat/completions
