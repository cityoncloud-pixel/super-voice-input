SVI_DB_PATH=data/super_voice_input.db
SVI_PROMPTS_DIR=prompts

# Electron 与手动 uvicorn 共用（桌面端会读此文件；不设则默认 127.0.0.1:8000）
# SVI_API_HOST=127.0.0.1
# SVI_API_PORT=8000
# 启动时是否自动打开悬浮窗：默认 1（主工作台 + 悬浮窗）；设为 0 则仅托盘打开（快捷键仍会按需创建悬浮窗）
# SVI_SHOW_OVERLAY_ON_START=1
# 与 npm run desktop:reload 配套：由 Electron 拉起的 uvicorn 加 --reload（改 local_api 自动重载）
# SVI_UVICORN_RELOAD=1
SVI_DEFAULT_STT_PROVIDER=doubao
SVI_DEFAULT_REWRITE_PROVIDER=deepseek

# Auto transcode recorded `.webm` into `.wav` (required for Doubao in this project).
# Needs `ffmpeg` in PATH, or set SVI_FFMPEG_PATH to the executable path.
SVI_TRANSCODE_WEBM=true
# SVI_FFMPEG_PATH=C:\path\to\ffmpeg.exe

# Desktop: automatically create a temporary public tunnel for Doubao to fetch audio.
# Requires `cloudflared` available in PATH (or set SVI_CLOUDFLARED_PATH).
SVI_AUTO_TUNNEL=1
# SVI_CLOUDFLARED_PATH=C:\path\to\cloudflared.exe

# --- 豆包转写：云端必须能 GET 到音频；本机 127.0.0.1 不可达，需内网穿透 ---
# ngrok 示例（与本机 API 同端口，例如 8000）：
#   终端1: python -m uvicorn local_api.main:app --host 127.0.0.1 --port 8000
#   终端2: ngrok http 8000
# 把 ngrok 给的 https 前缀填到下一行（无尾部斜杠）；豆包将访问：
#   {SVI_PUBLIC_BASE_URL}/files/audio/{session_id}/{filename}
SVI_PUBLIC_BASE_URL=

# 豆包转写前是否跳过「本机 GET 探测」音频 URL（仅当隧道对探测不兼容时设 1）
# SVI_SKIP_AUDIO_URL_PROBE=0

# STT: Doubao OpenSpeech (required for real transcription)
DOUBAO_BASE_URL=https://openspeech.bytedance.com/api/v3
DOUBAO_API_KEY=
# Align with verstory defaults: use one of the standard resource ids below.
# - volc.seedasr.auc (recommended)
# - volc.bigasr.auc
DOUBAO_RESOURCE_ID=volc.seedasr.auc
DOUBAO_USER_ID=svi-local-user
DOUBAO_LANGUAGE=
DOUBAO_ENABLE_ITN=true
DOUBAO_SUBMIT_PATH=/auc/bigmodel/submit
DOUBAO_QUERY_PATH=/auc/bigmodel/query
DOUBAO_POLL_INTERVAL_MS=1200
DOUBAO_POLL_TIMEOUT_MS=90000
# Optional: map local storage path to a full URL prefix
DOUBAO_AUDIO_URL_PREFIX=

# Rewrite: DeepSeek (required for real rewriting)
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_API_KEY=
DEEPSEEK_REWRITE_MODEL=deepseek-chat
DEEPSEEK_REWRITE_PATH=/chat/completions

# --- Output Router：文件类投递（G2；未配置时对应按钮会由 API 返回明确错误，不丢终稿）---
# 通用 Markdown 落盘目录（绝对或相对工作目录）
# SVI_MARKDOWN_OUTPUT_DIR=./out/markdown
# Obsidian：仓库根 + Inbox 相对子路径
# OBSIDIAN_VAULT_ROOT=
# SVI_OBSIDIAN_INBOX_REL=00_Inbox
# GAEH：项目根 + 相对 inbox
# SVI_GAEH_PROJECT_ROOT=
# SVI_GAEH_INBOX_REL=.gaeh/inbox
