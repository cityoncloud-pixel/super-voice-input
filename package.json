{
  "name": "super-voice-input-desktop",
  "version": "0.1.0",
  "private": true,
  "main": "desktop/main.js",
  "scripts": {
    "start": "electron .",
    "desktop": "electron .",
    "desktop:dev": "electron .",
    "desktop:reload": "cross-env SVI_UVICORN_RELOAD=1 electron .",
    "dev": "concurrently -k -n api,electron -c cyan,magenta \"npm run dev:api\" \"npm run dev:electron\"",
    "dev:api": "python -m uvicorn local_api.main:app --reload --host 127.0.0.1 --port 8000",
    "dev:electron": "cross-env SVI_SKIP_BACKEND=1 electronmon ."
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^31.7.7",
    "electronmon": "^2.0.4"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
